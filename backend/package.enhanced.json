{
  "name": "resqmission",
  "version": "2.0.0",
  "description": "Enhanced emergency response system with production-ready security and scalability",
  "main": "config/SecureServer.js",
  "scripts": {
    "start": "node config/SecureServer.js",
    "start:listener": "node config/RobustEmergencyListener.js",
    "dev": "nodemon config/SecureServer.js",
    "dev:listener": "nodemon config/RobustEmergencyListener.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write .",
    "db:migrate": "node scripts/migrate.js",
    "db:seed": "node scripts/seed.js",
    "health": "curl http://localhost:3000/health",
    "logs": "tail -f logs/combined.log",
    "logs:errors": "tail -f logs/error.log",
    "logs:emergency": "tail -f logs/emergency.log"
  },
  "keywords": [
    "emergency",
    "response",
    "healthcare",
    "resqmission",
    "nodejs",
    "express",
    "postgresql",
    "postgis",
    "jwt",
    "security",
    "scalability"
  ],
  "author": "ResQMission Team",
  "license": "MIT",
  "dependencies": {
    "express": "^5.2.1",
    "cors": "^2.8.6",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "crypto": "^1.0.1",
    "dotenv": "^17.2.4",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.1",
    "otp-generator": "^4.0.1",
    "pg": "^8.18.0",
    "twilio": "^5.12.1",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "rate-limit-redis": "^4.2.0",
    "redis": "^4.6.10",
    "bull": "^4.11.3",
    "opossum": "^8.1.0",
    "uuid": "^13.0.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "nodemon": "^3.1.11"
  },
  "devDependencies": {
    "nodemon": "^3.1.11",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "@types/jest": "^29.5.8"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/resqmission.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/resqmission/issues"
  },
  "homepage": "https://github.com/your-org/resqmission#readme",
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "backend/**/*.js",
      "!backend/config/**",
      "!backend/logs/**",
      "!backend/node_modules/**"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/__tests__/**/*.js"
    ]
  },
  "eslintConfig": {
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "extends": [
      "eslint:recommended"
    ],
    "parserOptions": {
      "ecmaVersion": 2022,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "warn",
      "no-unused-vars": "error",
      "prefer-const": "error",
      "no-var": "error"
    }
  },
  "prettier": {
    "semi": true,
    "trailingComma": "es5",
    "singleQuote": true,
    "printWidth": 100,
    "tabWidth": 2
  }
}
